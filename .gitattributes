# Auto-detect text files and normalize line endings to LF
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Python files
*.py text eol=lf
*.pyw text eol=lf

# JavaScript/Node
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf

# Dockerfiles
Dockerfile text eol=lf
.dockerignore text eol=lf

# Markdown
*.md text eol=lf

# YAML
*.yml text eol=lf
*.yaml text eol=lf

# CSS
*.css text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
